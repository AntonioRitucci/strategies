{
    "name": "Bollinger Breakout",
    "timeframe": "15m",
    "pairs": [
        "DOGE/USDT",
        "XRP/USDT"
    ],
    "config": {
        "pandas_ta": {
            "bbands_n1": {
                "name": "bbands",
                "parameters": [
                    {
                        "name": "close",
                        "type_": "pd.Series",
                        "df": true,
                        "value": "close"
                    },
                    {
                        "name": "length",
                        "type_": "int",
                        "df": false,
                        "value": "20"
                    },
                    {
                        "name": "std",
                        "type_": "int",
                        "df": false,
                        "value": "2"
                    },
                    {
                        "name": "ddof",
                        "type_": "int",
                        "df": false,
                        "value": "0"
                    },
                    {
                        "name": "mamode",
                        "type_": "str",
                        "df": false,
                        "value": "sma"
                    }
                ],
                "returns_columns": [
                    "lower",
                    "mid",
                    "upper",
                    "bandwidth",
                    "percent"
                ]
            }
        },
        "timeframes": {}
    },
    "signals": {
        "enter_long": {
            "type_": "cross_above",
            "column1": "close",
            "column2": "bbands_n1_upper",
            "side": true,
            "children": []
        },
        "enter_short": {
            "type_": "cross_below",
            "column1": "close",
            "column2": "bbands_n1_lower",
            "side": true,
            "children": []
        },
        "exit_long": {},
        "exit_short": {},
        "enter_long_cooldown": null,
        "enter_short_cooldown": null
    },
    "plot": {
        "main_plot": {
            "bbands_n1_upper": {
                "color": "gray",
                "type": "line"
            },
            "bbands_n1_lower": {
                "color": "gray",
                "type": "line"
            },
            "bbands_n1_mid": {
                "color": "orange",
                "type": "line"
            }
        },
        "subplots": {}
    },
    "notes": [],
    "risk": {
        "minimal_roi": [
            {
                "0": 0.2
            }
        ],
        "stoploss": -0.2,
        "leverage": 10.0,
        "useTimeLimit": false,
        "timeLimit": 10,
        "capital": 1000.0,
        "maxTrades": 3,
        "atrExit": false,
        "atrTp": 3.0,
        "atrSl": 1.0,
        "tauExit": false,
